<?xml version="1.0" encoding="utf-8"?>
<!--
    data_extraction_rules.xml — Mandarin Learn
    Android 12+ (API 31+) backup configuration — supersedes backup_rules.xml on newer devices.
    Mirrors the exclusion rules from backup_rules.xml.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="mandarin_learn.db" />
        <exclude domain="database" path="mandarin_learn.db-shm" />
        <exclude domain="database" path="mandarin_learn.db-wal" />
        <exclude domain="file" path="audio_cache/" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow device-to-device transfer of DataStore preferences (settings only) -->
        <include domain="file" path="datastore/" />
        <!-- Exclude database and audio cache from device transfer too -->
        <exclude domain="database" path="mandarin_learn.db" />
        <exclude domain="file" path="audio_cache/" />
    </device-transfer>
</data-extraction-rules>
