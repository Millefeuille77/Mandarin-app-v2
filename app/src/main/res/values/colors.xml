<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml — Mandarin Learn
    Raw hex color values. These are referenced by themes.xml for the XML-based AppTheme
    (used by the splash screen). The Compose theme reads from ui/theme/Color.kt directly.
    UX_SPECIFICATION.md §1.2 lists all token values.
-->
<resources>
