<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_foreground.xml — Mandarin Learn
    Adaptive icon foreground layer. Rendered as the Chinese character 中 ("middle/China"),
    centered on the safe-zone of an adaptive icon (108dp viewport, 72dp safe-zone for the
    glyph so launchers can mask circle/squircle/rounded-square without clipping).

    The white-on-blue palette matches the app theme (Primary #1565C0).
-->
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Chinese character 中 (zhōng) constructed from rectangles.
        Bounding box: 36..72 horizontally, 36..78 vertically (within the 27..81 safe zone).
        Strokes are 5dp wide for legibility at 48dp launcher size.
    -->

    <!-- Outer rectangle (口 component): top stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,40 L68,40 L68,46 L40,46 Z" />
    <!-- Outer rectangle: bottom stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,68 L68,68 L68,74 L40,74 Z" />
    <!-- Outer rectangle: left stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,40 L46,40 L46,74 L40,74 Z" />
    <!-- Outer rectangle: right stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M62,40 L68,40 L68,74 L62,74 Z" />

    <!-- Vertical stroke through the rectangle (the | of 中) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M51,30 L57,30 L57,84 L51,84 Z" />
</vector>
